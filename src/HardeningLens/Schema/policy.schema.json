{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xGreeny/hardening-lens/v1.1.0/src/HardeningLens/Schema/policy.schema.json",
  "title": "Hardening Lens policy gate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requireFullAssessment", "minimumEvidenceCoverage", "maximumErrors", "maximumFindings"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "requireFullAssessment": { "type": "boolean" },
    "minimumEvidenceCoverage": { "type": "number", "minimum": 0, "maximum": 100 },
    "maximumErrors": { "type": "integer", "minimum": 0 },
    "maximumUnknown": { "type": "integer", "minimum": 0 },
    "maximumExceptedCritical": { "type": "integer", "minimum": 0 },
    "exceptionExpiryWarningDays": { "type": "integer", "minimum": 0, "maximum": 3650 },
    "maximumExpiringExceptions": { "type": "integer", "minimum": 0 },
    "maximumFindings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Critical": { "type": "integer", "minimum": 0 },
        "High": { "type": "integer", "minimum": 0 },
        "Medium": { "type": "integer", "minimum": 0 },
        "Low": { "type": "integer", "minimum": 0 },
        "Info": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
